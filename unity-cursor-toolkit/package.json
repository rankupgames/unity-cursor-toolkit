{
  "name": "unity-cursor-toolkit",
  "displayName": "Unity Cursor Toolkit",
  "description": "Enhanced Unity development tools for VS Code/Cursor, including hot reload functionality",
  "version": "0.6.1052826",
  "publisher": "rankupgames",
  "icon": "TempIcon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rankupgames/unity-cursor-toolkit"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:Assets/",
    "workspaceContains:Assets",
    "workspaceContains:ProjectSettings/ProjectVersion.txt",
    "workspaceContains:**/ProjectSettings/ProjectVersion.txt",
    "workspaceContains:Assets/**/*.cs",
    "onStartupFinished",
    "workspaceContains:*.unity",
    "workspaceContains:*.cs",
    "onView:unityConsole",
    "onView:unityHierarchy",
    "onCommand:unity-cursor-toolkit.viewport.openPrototype",
    "onCommand:unity-cursor-toolkit.viewport.openSceneView",
    "onCommand:unity-cursor-toolkit.viewport.openGameView",
    "onCommand:unity-cursor-toolkit.viewport.openPlayerSceneView",
    "onCommand:unity-cursor-toolkit.viewport.openPlayerGameView",
    "onCommand:unity-cursor-toolkit.viewport.openInspector",
    "onCommand:unity-cursor-toolkit.viewport.openPackageManager",
    "onCommand:unity-cursor-toolkit.viewport.openCustomWindow",
    "onCommand:unity-cursor-toolkit.hierarchy.refresh",
    "onCommand:unity-cursor-toolkit.hierarchy.focus",
    "onCommand:unity-cursor-toolkit.remoteShell.launch",
    "onCommand:unity-cursor-toolkit.remoteShell.stop",
    "onCommand:unity-cursor-toolkit.remoteShell.status"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "configuration": [
      {
        "title": "Unity Cursor Toolkit",
        "properties": {
          "unityCursorToolkit.console.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable the Unity Console panel in the sidebar."
          },
          "unityCursorToolkit.console.autoStream": {
            "type": "boolean",
            "default": true,
            "description": "Automatically stream Unity console output to the panel."
          },
          "unityCursorToolkit.console.maxEntries": {
            "type": "number",
            "default": 1000,
            "minimum": 1,
            "maximum": 1000,
            "description": "Maximum console entries retained in the bounded ring buffer."
          },
          "unityCursorToolkit.hotReload.preferILPatch": {
            "type": "boolean",
            "default": true,
            "description": "Prefer IL patching over full asset refresh when in play mode."
          },
          "unityCursorToolkit.hotReload.ilPatchTimeout": {
            "type": "number",
            "default": 5000,
            "description": "Timeout (ms) for IL patch before falling back to full refresh."
          },
          "unityCursorToolkit.autoLaunchEditor": {
            "type": "boolean",
            "default": true,
            "description": "Automatically launch the installed Unity Editor for the linked project when attaching or opening viewport panels."
          },
          "unityCursorToolkit.unityEditorPath": {
            "type": "string",
            "default": "",
            "description": "Optional path to the installed Unity Editor executable. Leave empty to resolve from the linked project's ProjectVersion.txt or UNITY_CURSOR_TOOLKIT_UNITY_PATH."
          },
          "unityCursorToolkit.workspaceScanPaths": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "description": "Additional paths to scan for .code-workspace files."
          },
          "unityCursorToolkit.remoteShell.manifestPath": {
            "type": "string",
            "default": "${workspaceFolder}/remote_workspace/unity-shell.json",
            "description": "Path to the Unity VDD shell manifest."
          },
          "unityCursorToolkit.remoteShell.shellAppPath": {
            "type": "string",
            "default": "",
            "description": "Optional path to a built Unity VDD native shell app or executable. Leave empty to run the bundled Swift package with swift run."
          },
          "unityCursorToolkit.remoteShell.localPortBase": {
            "type": "number",
            "default": 48170,
            "description": "First local forwarded port for the Unity VDD shell. The control port uses the next port."
          }
        }
      }
    ],
    "commands": [
      {
        "command": "unity-cursor-toolkit.startConnection",
        "title": "Unity Toolkit: Start/Attach to Project"
      },
      {
        "command": "unity-cursor-toolkit.reloadConnection",
        "title": "Unity Toolkit: Reload Connection"
      },
      {
        "command": "unity-cursor-toolkit.stopConnection",
        "title": "Unity Toolkit: Stop Connection"
      },
      {
        "command": "unity-cursor-toolkit.console.clear",
        "title": "Unity Toolkit: Clear Console",
        "icon": "$(clear-all)"
      },
      {
        "command": "unity-cursor-toolkit.console.sendToChat",
        "title": "Unity Toolkit: Send Console to Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "unity-cursor-toolkit.console.copy",
        "title": "Unity Toolkit: Copy Console",
        "icon": "$(copy)"
      },
      {
        "command": "unity-cursor-toolkit.console.snapshot",
        "title": "Unity Toolkit: Console Snapshot"
      },
      {
        "command": "unity-cursor-toolkit.console.export",
        "title": "Unity Toolkit: Export Console Logs"
      },
      {
        "command": "unity-cursor-toolkit.resolveMeta",
        "title": "Unity Toolkit: Resolve Meta File"
      },
      {
        "command": "unity-cursor-toolkit.openProject",
        "title": "Unity Toolkit: Open Project"
      },
      {
        "command": "unity-cursor-toolkit.generateFolderStructure",
        "title": "Unity Toolkit: Generate Folder Structure"
      },
      {
        "command": "unity-cursor-toolkit.quickAccess",
        "title": "Unity Toolkit: Quick Actions"
      },
      {
        "command": "unity-cursor-toolkit.debug.attach",
        "title": "Unity Toolkit: Attach Debugger"
      },
      {
        "command": "unity-cursor-toolkit.playMode.enter",
        "title": "Unity Toolkit: Enter Play Mode",
        "icon": "$(play)"
      },
      {
        "command": "unity-cursor-toolkit.playMode.exit",
        "title": "Unity Toolkit: Exit Play Mode",
        "icon": "$(debug-stop)"
      },
      {
        "command": "unity-cursor-toolkit.playMode.pause",
        "title": "Unity Toolkit: Pause Play Mode",
        "icon": "$(debug-pause)"
      },
      {
        "command": "unity-cursor-toolkit.playMode.step",
        "title": "Unity Toolkit: Step Frame",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "unity-cursor-toolkit.screenshot",
        "title": "Unity Toolkit: Capture Screenshot",
        "icon": "$(device-camera)"
      },
      {
        "command": "unity-cursor-toolkit.viewport.openPrototype",
        "title": "Unity Toolkit: Open Scene View Prototype",
        "icon": "$(layout-panel)"
      },
      {
        "command": "unity-cursor-toolkit.viewport.openSceneView",
        "title": "Unity Toolkit: Open Scene View",
        "icon": "$(layout-panel)"
      },
      {
        "command": "unity-cursor-toolkit.viewport.openGameView",
        "title": "Unity Toolkit: Open Game View",
        "icon": "$(game)"
      },
      {
        "command": "unity-cursor-toolkit.viewport.openPlayerSceneView",
        "title": "Unity Toolkit: Open Player Scene View",
        "icon": "$(play)"
      },
      {
        "command": "unity-cursor-toolkit.viewport.openPlayerGameView",
        "title": "Unity Toolkit: Open Player Game View",
        "icon": "$(run)"
      },
      {
        "command": "unity-cursor-toolkit.viewport.openInspector",
        "title": "Unity Toolkit: Open Inspector",
        "icon": "$(inspect)"
      },
      {
        "command": "unity-cursor-toolkit.viewport.openPackageManager",
        "title": "Unity Toolkit: Open Package Manager",
        "icon": "$(package)"
      },
      {
        "command": "unity-cursor-toolkit.viewport.openCustomWindow",
        "title": "Unity Toolkit: Open Custom EditorWindow",
        "icon": "$(window)"
      },
      {
        "command": "unity-cursor-toolkit.hierarchy.focus",
        "title": "Unity Toolkit: Focus Hierarchy",
        "icon": "$(list-tree)"
      },
      {
        "command": "unity-cursor-toolkit.hierarchy.refresh",
        "title": "Unity Toolkit: Refresh Hierarchy",
        "icon": "$(refresh)"
      },
      {
        "command": "unity-cursor-toolkit.mcp.showServerPath",
        "title": "Unity Toolkit: Show MCP Server Path"
      },
      {
        "command": "unity-cursor-toolkit.mcp.copyClientConfig",
        "title": "Unity Toolkit: Copy MCP Client Config",
        "icon": "$(copy)"
      },
      {
        "command": "unity-cursor-toolkit.remoteShell.launch",
        "title": "Unity Toolkit: Launch Unity VDD Shell",
        "icon": "$(window)"
      },
      {
        "command": "unity-cursor-toolkit.remoteShell.stop",
        "title": "Unity Toolkit: Stop Unity VDD Shell",
        "icon": "$(debug-stop)"
      },
      {
        "command": "unity-cursor-toolkit.remoteShell.status",
        "title": "Unity Toolkit: Unity VDD Shell Status",
        "icon": "$(pulse)"
      }
    ],
    "debuggers": [
      {
        "type": "unityCursorToolkit.debug",
        "label": "Unity (Mono)",
        "configurationAttributes": {
          "attach": {
            "properties": {
              "debugPort": {
                "type": "number",
                "default": 56000,
                "description": "Mono debugger port (from -debuggerPort or default 56000)"
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "Attach to Unity Editor",
            "description": "Attach to Unity Editor's Mono debugger",
            "body": {
              "type": "unityCursorToolkit.debug",
              "request": "attach",
              "name": "Attach to Unity Editor",
              "debugPort": 56000
            }
          },
          {
            "label": "Attach to Unity Player",
            "description": "Attach to Unity Player (Development build + Script Debugging)",
            "body": {
              "type": "unityCursorToolkit.debug",
              "request": "attach",
              "name": "Attach to Unity Player",
              "debugPort": 56000
            }
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "unityCursorToolkit",
          "title": "Unity Cursor",
          "icon": "TempIcon.png"
        }
      ]
    },
    "views": {
      "unityCursorToolkit": [
        {
          "id": "unityHierarchy",
          "name": "Hierarchy",
          "visibility": "visible"
        },
        {
          "id": "unityConsole",
          "name": "Unity Console",
          "type": "webview",
          "icon": "$(terminal)",
          "when": "config.unityCursorToolkit.console.enabled",
          "visibility": "collapsed"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "unity-cursor-toolkit.hierarchy.refresh",
          "when": "view == unityHierarchy",
          "group": "navigation@1"
        },
        {
          "command": "unity-cursor-toolkit.viewport.openSceneView",
          "when": "view == unityHierarchy",
          "group": "navigation@2"
        },
        {
          "command": "unity-cursor-toolkit.viewport.openGameView",
          "when": "view == unityHierarchy",
          "group": "navigation@3"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "dev:watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node test/run-tests.js && node test/simplified-context-tests.js && node test/remote-shell-tests.js",
    "test:unity-internal": "node scripts/run-internal-unity-smoke.js",
    "dev:unity-viewport": "node scripts/run-internal-viewport-stream.js",
    "spike:editor-windows": "node scripts/run-editor-window-capture-spike.js",
    "probe:editor-window-stream": "node scripts/probe-editor-window-stream.js",
    "measure:editor-stream": "node scripts/measure-editor-streaming.js",
    "build:viewport-service": "node scripts/build-viewport-service.js",
    "run:viewport-service": "node scripts/run-viewport-service.js",
    "measure:viewport-service": "node scripts/measure-viewport-service.js",
    "probe:viewport-service": "node scripts/probe-viewport-service.js",
    "audit:unity-without-editor": "node scripts/audit-unity-without-editor.js",
    "proof:windows-unity-without-editor": "node scripts/run-windows-unity-without-editor-proof.js",
    "proof:windows-unity-without-editor:preflight": "node scripts/run-windows-unity-without-editor-proof.js --preflight-only",
    "proof:windows-unity-without-editor:remote": "node scripts/run-remote-windows-unity-without-editor-proof.js",
    "proof:windows-unity-without-editor:import": "node scripts/import-windows-unity-without-editor-proof.js",
    "smoke:installed-cursor-viewports": "node scripts/smoke-installed-cursor-viewports.js",
    "unity:license": "node scripts/unity-license.js",
    "remote-shell": "node out/remote-shell/sidecarCli.js",
    "mcp:serve": "node out/mcp/server.js",
    "package": "vsce package",
    "publish": "vsce publish",
    "install:extension": "npm install",
    "build": "npm run compile",
    "bundle": "node scripts/esbuild-bundle.js",
    "bundle:watch": "node scripts/esbuild-bundle.js --watch",
    "check:unused": "tsc -p ./ --noEmit --noUnusedLocals --noUnusedParameters",
    "validate:vendor": "node scripts/validate-vendored-unterm.js",
    "validate": "npm run compile && npm run check:unused && npm test && npm run validate:vendor && npm run audit",
    "dev": "npm run compile && npx vsce package --no-dependencies && (cursor --install-extension *.vsix --force 2>/dev/null || code --install-extension *.vsix --force)",
    "bump": "node scripts/bump-version.js && npm run compile && npx vsce package --no-dependencies && (cursor --install-extension *.vsix --force 2>/dev/null || code --install-extension *.vsix --force)",
    "bump:minor": "npm version minor && npm run compile && npx vsce package --no-dependencies && (cursor --install-extension *.vsix 2>/dev/null || code --install-extension *.vsix)",
    "local": "npx vsce package --no-dependencies && (cursor --install-extension *.vsix --force 2>/dev/null || code --install-extension *.vsix --force)",
    "audit": "npm audit --omit=dev && npm audit"
  },
  "overrides": {
    "form-data": "4.0.6",
    "hono": "4.12.25",
    "undici": "7.28.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^16.11.7",
    "@types/vscode": "^1.60.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "fs-extra": "^10.0.0",
    "ovsx": "^0.10.11",
    "ts-node": "^10.9.2",
    "typescript": "^4.5.5"
  },
  "keywords": [
    "unity",
    "cursor",
    "toolkit",
    "hot reload",
    "live reload",
    "csharp",
    "unity3d",
    "vs-code"
  ],
  "author": {
    "name": "Rank Up Games LLC",
    "url": "https://github.com/rankupgames"
  },
  "bugs": {
    "url": "https://github.com/rankupgames/unity-cursor-toolkit/issues"
  },
  "homepage": "https://github.com/rankupgames/unity-cursor-toolkit#readme",
  "galleryBanner": {
    "color": "#2C2C2C",
    "theme": "dark"
  }
}
