{
  "name": "unity-cursor-toolkit",
  "displayName": "Unity Cursor Toolkit",
  "description": "Enhanced Unity development tools for VS Code/Cursor, including hot reload functionality",
  "version": "0.2.20250320",
  "publisher": "rankupgames",
  "icon": "TempIcon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rankupgames/unity-cursor-toolkit"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:Assets/",
    "workspaceContains:*.unity",
    "workspaceContains:*.cs"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Unity Cursor Toolkit",
      "properties": {
        "unity-cursor-toolkit.riderIntegration": {
          "type": "boolean",
          "default": false,
          "description": "Enable Rider C# intelligence integration"
        },
        "unity-cursor-toolkit.riderPath": {
          "type": "string",
          "description": "Path to Rider installation"
        }
      }
    },
    "commands": [
      {
        "command": "unity-cursor-toolkit.enableHotReload",
        "title": "Unity Toolkit: Enable Hot Reload"
      },
      {
        "command": "unity-cursor-toolkit.disableHotReload",
        "title": "Unity Toolkit: Disable Hot Reload"
      },
      {
        "command": "unity-cursor-toolkit.forceReload",
        "title": "Unity Toolkit: Force Reload Unity"
      },
      {
        "command": "unity-cursor-toolkit.showContextMenu",
        "title": "Unity Toolkit: Show Context Menu"
      },
      {
        "command": "unity-cursor-toolkit.attachUnityProject",
        "title": "Unity Toolkit: Select Unity Project"
      },
      {
        "command": "unity-cursor-toolkit.toggleRiderIntegration",
        "title": "Unity Toolkit: Toggle Rider Integration"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^16.11.7",
    "@types/vscode": "^1.60.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^4.5.5"
  },
  "keywords": [
    "unity",
    "cursor",
    "toolkit",
    "hot reload",
    "live reload",
    "csharp",
    "unity3d",
    "vs-code"
  ],
  "author": {
    "name": "Rank Up Games LLC",
    "url": "https://github.com/rankupgames"
  },
  "bugs": {
    "url": "https://github.com/rankupgames/unity-cursor-toolkit/issues"
  },
  "homepage": "https://github.com/rankupgames/unity-cursor-toolkit#readme",
  "galleryBanner": {
    "color": "#2C2C2C",
    "theme": "dark"
  }
}
