{
  "name": "unity-cursor-toolkit",
  "displayName": "Unity Cursor Toolkit",
  "description": "Enhanced Unity development tools for VS Code/Cursor, including hot reload functionality",
  "version": "0.6.2041326",
  "publisher": "rankupgames",
  "icon": "TempIcon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rankupgames/unity-cursor-toolkit"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:Assets/",
    "workspaceContains:*.unity",
    "workspaceContains:*.cs",
    "onView:unityConsole"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "configuration": [
      {
        "title": "Unity Cursor Toolkit",
        "properties": {
          "unityCursorToolkit.console.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable the Unity Console panel in the sidebar."
          },
          "unityCursorToolkit.console.autoStream": {
            "type": "boolean",
            "default": true,
            "description": "Automatically stream Unity console output to the panel."
          },
          "unityCursorToolkit.console.maxEntries": {
            "type": "number",
            "default": 10000,
            "description": "Maximum console entries retained in the ring buffer."
          },
          "unityCursorToolkit.hotReload.preferILPatch": {
            "type": "boolean",
            "default": true,
            "description": "Prefer IL patching over full asset refresh when in play mode."
          },
          "unityCursorToolkit.hotReload.ilPatchTimeout": {
            "type": "number",
            "default": 5000,
            "description": "Timeout (ms) for IL patch before falling back to full refresh."
          },
          "unityCursorToolkit.workspaceScanPaths": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "description": "Additional paths to scan for .code-workspace files."
          }
        }
      }
    ],
    "commands": [
      {
        "command": "unity-cursor-toolkit.startConnection",
        "title": "Unity Toolkit: Start/Attach to Project"
      },
      {
        "command": "unity-cursor-toolkit.reloadConnection",
        "title": "Unity Toolkit: Reload Connection"
      },
      {
        "command": "unity-cursor-toolkit.stopConnection",
        "title": "Unity Toolkit: Stop Connection"
      },
      {
        "command": "unity-cursor-toolkit.console.clear",
        "title": "Unity Toolkit: Clear Console",
        "icon": "$(clear-all)"
      },
      {
        "command": "unity-cursor-toolkit.console.sendToChat",
        "title": "Unity Toolkit: Send Console to Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "unity-cursor-toolkit.console.copy",
        "title": "Unity Toolkit: Copy Console",
        "icon": "$(copy)"
      },
      {
        "command": "unity-cursor-toolkit.console.snapshot",
        "title": "Unity Toolkit: Console Snapshot"
      },
      {
        "command": "unity-cursor-toolkit.console.export",
        "title": "Unity Toolkit: Export Console Logs"
      },
      {
        "command": "unity-cursor-toolkit.resolveMeta",
        "title": "Unity Toolkit: Resolve Meta File"
      },
      {
        "command": "unity-cursor-toolkit.openProject",
        "title": "Unity Toolkit: Open Project"
      },
      {
        "command": "unity-cursor-toolkit.generateFolderStructure",
        "title": "Unity Toolkit: Generate Folder Structure"
      },
      {
        "command": "unity-cursor-toolkit.quickAccess",
        "title": "Unity Toolkit: Quick Actions"
      },
      {
        "command": "unity-cursor-toolkit.debug.attach",
        "title": "Unity Toolkit: Attach Debugger"
      },
      {
        "command": "unity-cursor-toolkit.playMode.enter",
        "title": "Unity Toolkit: Enter Play Mode",
        "icon": "$(play)"
      },
      {
        "command": "unity-cursor-toolkit.playMode.exit",
        "title": "Unity Toolkit: Exit Play Mode",
        "icon": "$(debug-stop)"
      },
      {
        "command": "unity-cursor-toolkit.playMode.pause",
        "title": "Unity Toolkit: Pause Play Mode",
        "icon": "$(debug-pause)"
      },
      {
        "command": "unity-cursor-toolkit.playMode.step",
        "title": "Unity Toolkit: Step Frame",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "unity-cursor-toolkit.screenshot",
        "title": "Unity Toolkit: Capture Screenshot",
        "icon": "$(device-camera)"
      }
    ],
    "debuggers": [
      {
        "type": "unityCursorToolkit.debug",
        "label": "Unity (Mono)",
        "configurationAttributes": {
          "attach": {
            "properties": {
              "debugPort": {
                "type": "number",
                "default": 56000,
                "description": "Mono debugger port (from -debuggerPort or default 56000)"
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "Attach to Unity Editor",
            "description": "Attach to Unity Editor's Mono debugger",
            "body": {
              "type": "unityCursorToolkit.debug",
              "request": "attach",
              "name": "Attach to Unity Editor",
              "debugPort": 56000
            }
          },
          {
            "label": "Attach to Unity Player",
            "description": "Attach to Unity Player (Development build + Script Debugging)",
            "body": {
              "type": "unityCursorToolkit.debug",
              "request": "attach",
              "name": "Attach to Unity Player",
              "debugPort": 56000
            }
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "unityCursorToolkit",
          "title": "Unity Cursor",
          "icon": "TempIcon.png"
        }
      ]
    },
    "views": {
      "unityCursorToolkit": [
        {
          "id": "unityConsole",
          "name": "Unity Console",
          "type": "webview",
          "icon": "$(terminal)",
          "when": "config.unityCursorToolkit.console.enabled"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "dev:watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node test/run-tests.js",
    "package": "vsce package",
    "publish": "vsce publish",
    "install:extension": "npm install",
    "build": "npm run compile",
    "bundle": "node scripts/esbuild-bundle.js",
    "bundle:watch": "node scripts/esbuild-bundle.js --watch",
    "dev": "npm run compile && npx vsce package --no-dependencies && (cursor --install-extension *.vsix --force 2>/dev/null || code --install-extension *.vsix --force)",
    "bump": "node scripts/bump-version.js && npm run compile && npx vsce package --no-dependencies && (cursor --install-extension *.vsix --force 2>/dev/null || code --install-extension *.vsix --force)",
    "bump:minor": "npm version minor && npm run compile && npx vsce package --no-dependencies && (cursor --install-extension *.vsix 2>/dev/null || code --install-extension *.vsix)",
    "local": "npx vsce package --no-dependencies && (cursor --install-extension *.vsix --force 2>/dev/null || code --install-extension *.vsix --force)",
    "audit": "npm audit --omit=dev; npm audit"
  },
  "overrides": {
    "undici": ">=7.10.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^16.11.7",
    "@types/vscode": "^1.60.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "fs-extra": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^4.5.5"
  },
  "keywords": [
    "unity",
    "cursor",
    "toolkit",
    "hot reload",
    "live reload",
    "csharp",
    "unity3d",
    "vs-code"
  ],
  "author": {
    "name": "Rank Up Games LLC",
    "url": "https://github.com/rankupgames"
  },
  "bugs": {
    "url": "https://github.com/rankupgames/unity-cursor-toolkit/issues"
  },
  "homepage": "https://github.com/rankupgames/unity-cursor-toolkit#readme",
  "galleryBanner": {
    "color": "#2C2C2C",
    "theme": "dark"
  }
}
